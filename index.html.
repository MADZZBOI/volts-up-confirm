<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Volts Up</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: #0A0F0C;
    color: #ffffff;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 24px;
  }
  .card {
    background: #121815;
    border: 1px solid #3DDC8440;
    border-radius: 20px;
    padding: 40px 32px;
    max-width: 400px;
    width: 100%;
    text-align: center;
  }
  .icon { font-size: 48px; margin-bottom: 16px; }
  h1 { font-size: 22px; font-weight: 700; margin-bottom: 12px; }
  p { font-size: 15px; color: #9BA69F; line-height: 1.5; }
  .footer { margin-top: 24px; font-size: 12px; color: #5F6B62; }
</style>
</head>
<body>
  <div class="card" id="card">
    <div class="icon" id="icon">⏳</div>
    <h1 id="title">Loading…</h1>
    <p id="message"></p>
    <div class="footer">Volts Up — you can close this tab</div>
  </div>

  <script>
    const params = new URLSearchParams(window.location.search);
    const status = params.get("status");
    const name = params.get("name");
    const message = params.get("message");

    const iconEl = document.getElementById("icon");
    const titleEl = document.getElementById("title");
    const messageEl = document.getElementById("message");
    const cardEl = document.getElementById("card");

    let icon = "✅", title = "Done", text = "", accent = "#3DDC84";

    if (status === "approved") {
      icon = "✅"; title = "Charger Approved";
      text = name ? `"${name}" is now live on the map for everyone.` : "The charger is now live on the map.";
      accent = "#3DDC84";
    } else if (status === "rejected") {
      icon = "❌"; title = "Charger Rejected";
      text = name ? `"${name}" has been rejected and will stay hidden.` : "The charger has been rejected.";
      accent = "#E8544B";
    } else if (status === "unauthorized") {
      icon = "🔒"; title = "Not Authorized";
      text = "This link isn't valid.";
      accent = "#E8544B";
    } else {
      icon = "⚠️"; title = "Something Went Wrong";
      text = message || "An unexpected error occurred.";
      accent = "#E8544B";
    }

    iconEl.textContent = icon;
    titleEl.textContent = title;
    titleEl.style.color = accent;
    messageEl.textContent = text;
    cardEl.style.borderColor = accent + "40";
  </script>
</body>
</html>
